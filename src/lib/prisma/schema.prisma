generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite" // easiest to start
  url      = env("DATABASE_URL")
}

model Plant {
  id       String  @id @default(cuid())
  name     String
  category String
  price    Float
  stock    Int
  userId  String // required
  createdAt DateTime @default(now())
}